configfile: "config/config.yaml"

ASSETS = config["assets"]
ASSET_KEYS = [asset["key"] for asset in ASSETS]
ASSET_CONFIG = {asset["key"]: asset for asset in ASSETS}

DB_DIR = config["db"]["dir"]
TABLE = config["db"]["table"]

LAGS = ",".join(str(x) for x in config["features"]["lags"])
WINS = ",".join(str(x) for x in config["features"]["rolling_windows"])
TEST_SIZE = config["model"]["test_size"]
RECENT_MONTHS = config["reporting"]["recent_months"]
LLM_MODEL = config["llm"]["model"]
LLM_HOST = config["llm"]["host"]


rule all:
    input:
        expand("reports/metrics/{asset}.json", asset=ASSET_KEYS),
        expand("reports/preds/{asset}.csv", asset=ASSET_KEYS),
        expand("reports/notes/{asset}.md", asset=ASSET_KEYS),
        "reports/cross_asset_metrics.csv",
        "reports/cross_asset_summary.json",
        "reports/plots/recent_returns.png",
        "reports/plots/model_metrics.png",
        "reports/plots/prediction_compression.png",
        "reports/plots/actual_vs_predicted.png",
        "reports/cross_asset_note.md"


rule ingest:
    output:
        "data/raw/{asset}.csv"
    params:
        series_id=lambda wildcards: ASSET_CONFIG[wildcards.asset]["fred_id"],
        asset_key=lambda wildcards: wildcards.asset,
        asset_name=lambda wildcards: ASSET_CONFIG[wildcards.asset]["name"]
    shell:
        (
            "mkdir -p data/raw && "
            "python src/fetch_tseries.py "
            "--series-id {params.series_id} "
            "--asset-key {params.asset_key} "
            "--asset-name '{params.asset_name}' "
            "--out-csv {output}"
        )


rule store:
    input:
        "data/raw/{asset}.csv"
    output:
        db="data/sqlite/{asset}.db"
    params:
        table=TABLE
    shell:
        (
            "mkdir -p {DB_DIR} && "
            "python src/store_sqlite.py "
            "--in-csv {input} "
            "--db-path {output.db} "
            "--table {params.table}"
        )


rule features:
    input:
        db="data/sqlite/{asset}.db"
    output:
        "data/processed/{asset}_features.csv"
    params:
        table=TABLE
    shell:
        (
            "mkdir -p data/processed && "
            "python src/features.py "
            "--db-path {input.db} "
            "--in-table {params.table} "
            "--out-csv {output} "
            "--lags {LAGS} "
            "--windows {WINS}"
        )


rule train_eval:
    input:
        "data/processed/{asset}_features.csv"
    output:
        metrics="reports/metrics/{asset}.json",
        preds="reports/preds/{asset}.csv"
    shell:
        (
            "mkdir -p reports/metrics reports/preds && "
            "python src/train_eval.py "
            "--features-csv {input} "
            "--out-metrics {output.metrics} "
            "--out-preds {output.preds} "
            "--test-size {TEST_SIZE}"
        )


rule llm_report:
    input:
        metrics="reports/metrics/{asset}.json",
        preds="reports/preds/{asset}.csv"
    output:
        "reports/notes/{asset}.md"
    shell:
        (
            "mkdir -p reports/notes && "
            "python src/llm_report.py "
            "--metrics-json {input.metrics} "
            "--preds-csv {input.preds} "
            "--out-md {output} "
            "--recent-months {RECENT_MONTHS} "
            "--model {LLM_MODEL} "
            "--host {LLM_HOST}"
        )


rule compare_assets:
    input:
        metrics=expand("reports/metrics/{asset}.json", asset=ASSET_KEYS),
        preds=expand("reports/preds/{asset}.csv", asset=ASSET_KEYS)
    output:
        summary_csv="reports/cross_asset_metrics.csv",
        summary_json="reports/cross_asset_summary.json"
    shell:
        (
            "python src/compare_assets.py "
            "--metrics-json {input.metrics} "
            "--preds-csv {input.preds} "
            "--out-csv {output.summary_csv} "
            "--out-json {output.summary_json} "
            "--recent-months {RECENT_MONTHS}"
        )


rule plot_assets:
    input:
        metrics=expand("reports/metrics/{asset}.json", asset=ASSET_KEYS),
        preds=expand("reports/preds/{asset}.csv", asset=ASSET_KEYS)
    output:
        "reports/plots/recent_returns.png",
        "reports/plots/model_metrics.png",
        "reports/plots/prediction_compression.png",
        "reports/plots/actual_vs_predicted.png"
    shell:
        (
            "MPLCONFIGDIR=/tmp/matplotlib-cache XDG_CACHE_HOME=/tmp "
            "python src/plot_assets.py "
            "--metrics-json {input.metrics} "
            "--preds-csv {input.preds} "
            "--out-dir reports/plots "
            "--recent-months {RECENT_MONTHS}"
        )


rule cross_asset_report:
    input:
        "reports/cross_asset_summary.json"
    output:
        "reports/cross_asset_note.md"
    shell:
        (
            "python src/cross_asset_report.py "
            "--summary-json {input} "
            "--out-md {output} "
            "--model {LLM_MODEL} "
            "--host {LLM_HOST}"
        )
